APP_ENV=development
APP_NAME=BuildWise AI
API_BASE_URL=http://localhost:8000
FRONTEND_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# Replace with a strong secret in production. Placeholder keys disable admin uploads when APP_ENV=production.
ADMIN_API_KEY=change-this-before-production

SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=authority-documents

EMBEDDING_PROVIDER=sentence-transformers
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIMENSIONS=384

LLM_PROVIDER=local
LLM_MODEL=
GEMINI_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=
OPENAI_API_KEY=

RAG_TOP_K=8
RAG_MIN_SIMILARITY=0.18
MAX_UPLOAD_MB=25
