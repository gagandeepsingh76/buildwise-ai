# BuildWise AI shared environment

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Backend
APP_ENV=development
APP_NAME=BuildWise AI
API_BASE_URL=http://localhost:8000
FRONTEND_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
ADMIN_API_KEY=change-this-before-production

# Supabase
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=
SUPABASE_STORAGE_BUCKET=authority-documents

# Embeddings: sentence-transformers is the production CPU-friendly default.
EMBEDDING_PROVIDER=sentence-transformers
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIMENSIONS=384

# LLM provider: local | gemini | groq | openrouter | openai
LLM_PROVIDER=local
LLM_MODEL=
GEMINI_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=
OPENAI_API_KEY=

# Retrieval
RAG_TOP_K=8
RAG_MIN_SIMILARITY=0.18
MAX_UPLOAD_MB=25
